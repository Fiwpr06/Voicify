# Voicify Environment Configuration Template
# Copy this file to .env and fill in your actual values
# The .env file should be added to .gitignore for security

# Database Configuration (Required)
DATABASE_SERVER=localhost
DATABASE_PORT=1433
DATABASE_NAME=VoicifyDB
DATABASE_USERNAME=sa
DATABASE_PASSWORD=your_database_password_here

# Email Configuration (Optional - only if email features are needed)
# Note: These will override values in email.properties
EMAIL_ENABLED=true
EMAIL_SMTP_HOST=smtp.gmail.com
EMAIL_SMTP_PORT=587
EMAIL_USERNAME=your_email@gmail.com
EMAIL_PASSWORD=your_app_password_here
EMAIL_FROM=your_email@gmail.com

# API Keys (Optional - for enhanced features)
TRANSLATION_GEMINI_API_KEY=your_gemini_api_key_here

# Application Settings
APP_BASE_URL=http://localhost:8080
LOGGING_LEVEL=INFO

# Vosk Model Path (adjust if needed)
VOSK_MODEL_PATH=./library/vosk-en-us-0.15

# Security Settings
SECURITY_SESSION_TIMEOUT=3600
SECURITY_PASSWORD_MIN_LENGTH=8
